# ===========================================================================
# Yaqadha (يقظة) — Algeria Wildfire Alert Bot — environment configuration
# Copy this file to ".env" and fill in the real values. NEVER commit ".env".
# ===========================================================================

# --- REQUIRED ---------------------------------------------------------------

# Telegram bot token from @BotFather (https://t.me/BotFather -> /newbot)
TELEGRAM_BOT_TOKEN=123456789:ABCdefGhIJKlmNoPQRstuVWxyZ

# NASA FIRMS MAP_KEY (free): https://firms.modaps.eosdis.nasa.gov/api/map_key/
FIRMS_MAP_KEY=your_firms_map_key_here

# --- OPTIONAL ---------------------------------------------------------------

# Public channel to broadcast every new hotspot to. Leave empty to disable.
# Use the numeric channel id (e.g. -1001234567890) or @channelusername.
# The bot must be an ADMIN of the channel to post.
TELEGRAM_CHANNEL_ID=

# FIRMS dataset to query. Common NRT options:
#   VIIRS_SNPP_NRT, VIIRS_NOAA20_NRT, VIIRS_NOAA21_NRT, MODIS_NRT
FIRMS_DATASET=VIIRS_SNPP_NRT

# How often to poll FIRMS, in minutes (default 60).
POLL_INTERVAL_MINUTES=60

# How many days of data to request from FIRMS per poll (1-5, default 5).
# IMPORTANT: do NOT use 1. FIRMS "day 1" is the single most-recent day bucket,
# which is frequently EMPTY because near-real-time detections arrive with an
# ingestion delay. A real, ongoing fire may only appear at day_range >= 2, so
# day_range=1 can return zero results even while fires are actively burning.
# We default to 5 (the max) so the gas-flare filter below also has enough
# distinct days of data to spot static sources from the very first poll.
FIRMS_DAY_RANGE=5

# Alert radius in kilometers for GPS subscribers (default 15).
ALERT_RADIUS_KM=15

# Minimum FIRMS confidence to alert on. For VIIRS use one of: l, n, h
# (low / nominal / high). For MODIS this is a 0-100 number.
# Set to "n" to skip low-confidence detections, or leave empty to alert on all.
MIN_CONFIDENCE=n

# --- Gas-flare / static thermal source suppression ---
# Oil & gas regions (Ouargla, Hassi Messaoud, Hassi R'Mel, In Amenas...) show
# permanent gas flares that FIRMS reports as thermal hotspots — these are NOT
# wildfires. The bot learns them automatically: any ~1km cell detected on at
# least FLARE_MIN_DAYS distinct days within the last FLARE_WINDOW_DAYS is treated
# as a persistent industrial source and filtered out of alerts.
FILTER_STATIC_SOURCES=true
FLARE_MIN_DAYS=3
FLARE_WINDOW_DAYS=10

# --- Reverse geocoding (Nominatim / OpenStreetMap, no API key) ---
# Names the nearest real place in alerts (e.g. "بجاية — 14 كم جنوب شرق") instead
# of just the wilaya. Results are cached in SQLite and requests are rate-limited
# to Nominatim's fair-use policy. Set to false to disable and use wilaya names.
ENABLE_GEOCODING=true
# Language for geocoded place names: ar (default), fr, or en.
GEOCODING_LANGUAGE=ar

# Path to the SQLite database file (default yaqadha.db in project root).
DATABASE_PATH=yaqadha.db

# Log level: DEBUG, INFO, WARNING, ERROR (default INFO).
LOG_LEVEL=INFO

# Network timeout (seconds) for Telegram API calls. Raise it on slow or
# intermittent connections to avoid spurious "TimedOut" errors (default 20).
TELEGRAM_TIMEOUT=20

# Optional proxy for reaching Telegram, useful where it is throttled/blocked.
# Examples: http://127.0.0.1:8080  or  socks5://127.0.0.1:9050
# (socks proxies require the extra package: pip install "httpx[socks]")
TELEGRAM_PROXY=
